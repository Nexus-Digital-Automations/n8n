// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CodeDiffMessage > Basic Rendering > should render code diff message correctly 1`] = `
<div>
  <div
    class="message"
  >
    <!--v-if-->
    
    <div
      class="code-diff"
      content="@@ -1,3 +1,3 @@
-old line
+new line
 unchanged line"
      streaming="false"
      title="Code changes description"
    />
    
    <!--v-if-->
  </div>
</div>
`;
